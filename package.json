{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky install",
    "commit": "cz"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "cli": "link:/@commitlint/cli",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mockjs": "^1.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.1",
    "vite-plugin-mock": "^3.0.2",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "eslint --fix",
      "eslint",
      "prettier --write",
      "npm run test"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "cz-git": {
    "types": [
      {
        "value": "feat",
        "name": "feat: ✨ 新功能"
      },
      {
        "value": "fix",
        "name": "fix: 🐛 修复bug"
      },
      {
        "value": "docs",
        "name": "docs: 📝 文档"
      },
      {
        "value": "style",
        "name": "style: 💄 格式"
      },
      {
        "value": "refactor",
        "name": "refactor: ♻️ 重构"
      },
      {
        "value": "test",
        "name": "test: ✅ 测试"
      },
      {
        "value": "chore",
        "name": "chore: 🔧 构建/工具"
      }
    ],
    "scopes": [
      "user",
      "auth",
      "permission",
      "dashboard"
    ],
    "messages": {
      "type": "请选择提交类型:",
      "scope": "请选择影响范围（可选）:",
      "subject": "请简要描述提交:",
      "confirmCommit": "确认提交？"
    }
  }
}
